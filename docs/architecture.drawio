<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram name="DASH 2.0 Queue POC" id="dash2-queue-poc">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- AppHost container -->
        <mxCell id="apphost" value="SignalRQueueDemo.AppHost — .NET Aspire orchestrator (everything below runs locally, zero manual wiring)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1320" height="920" as="geometry" />
        </mxCell>

        <!-- Public trust zone -->
        <mxCell id="publiczone" value="PUBLIC TRUST ZONE — no user auth; CORS + anti-forgery/API-key hardening only" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=12;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="360" height="360" as="geometry" />
        </mxCell>
        <mxCell id="checkin" value="angular/public-checkin&#10;Kiosk check-in form + document upload&#10;(Node build → nginx container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="150" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="display" value="angular/queue-display&#10;Public queue status board&#10;(Node build → nginx container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="250" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="blazorpublic" value="SignalRQueueDemo.Web (Blazor Server)&#10;public check-in + display pages&#10;(same experiences, no REST — shared services in-process)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="110" y="350" width="300" height="90" as="geometry" />
        </mxCell>

        <!-- Internal trust zone -->
        <mxCell id="internalzone" value="INTERNAL TRUST ZONE — mock staff auth (models Entra ID boundary)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=12;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="360" height="280" as="geometry" />
        </mxCell>
        <mxCell id="staff" value="angular/internal-queue&#10;Staff call-next console + view uploaded docs&#10;(Node build → nginx container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="550" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="blazorstaff" value="SignalRQueueDemo.Web (Blazor Server)&#10;internal call-next page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="110" y="660" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- API -->
        <mxCell id="api" value="SignalRQueueDemo.ApiService&#10;ASP.NET Core minimal API (.NET 10)&#10;&#10;GET /checkin/token  ← issues check-in token (public)&#10;POST /checkin · POST /queue/call-next&#10;POST /queue/{id}/complete · GET /queue&#10;GET /queue/since/{seq}  ← reconnect catch-up&#10;POST /checkin/{id}/documents  ← upload (public)&#10;GET /queue/{id}/documents(/{docId})  ← staff&#10;&#10;StaffAuthFilter (X-Staff-Key) · CheckInTokenFilter (HMAC)&#10;+ restricted CORS (KnownFrontends) on REST + hub&#10;&#10;QueueHub (SignalR, self-hosted per ADR-0001)&#10;broadcasts QueueUpdated with monotonic seq #" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="560" y="240" width="360" height="290" as="geometry" />
        </mxCell>

        <!-- Contracts -->
        <mxCell id="contracts" value="SignalRQueueDemo.Contracts&#10;shared DTOs/records — referenced by API + Blazor;&#10;mirrored as TypeScript types for Angular" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="560" y="110" width="360" height="80" as="geometry" />
        </mxCell>

        <!-- Persistence -->
        <mxCell id="sqlite" value="SQLite (EF Core)&#10;IQueueRepository default impl" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1040" y="120" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="azurite" value="Azurite emulator&#10;Table Storage: IQueueRepository alt impl&#10;Blob Storage: uploaded documents" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1040" y="280" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sigemu" value="Azure SignalR Emulator (serverless mode)&#10;container only exists when UseAzureSignalR=true&#10;never a real Azure resource — see AzureSignalRDefaultModeStub&#10;for the (never-invoked) production/default-mode path" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1040" y="450" width="220" height="110" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="REST + SignalR (+ polling fallback)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="checkin" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="SignalR: QueueUpdated" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="display" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="REST: call-next/complete + SignalR" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="staff" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="HubConnection direct + shared services" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;" edge="1" parent="1" source="blazorpublic" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;" edge="1" parent="1" source="blazorstaff" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="EF Core" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="api" target="sqlite">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="Table + Blob SDKs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="api" target="azurite">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="AzureSignalRServerlessDemoService:&#10;ServiceHubContext push + a client&#10;connected directly to the emulator" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="api" target="sigemu">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#d79b00;" edge="1" parent="1" source="contracts" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
