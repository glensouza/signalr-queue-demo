{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "QueueDb": "Data Source=App_Data/queue.db"
  },
  "Persistence": {
    "Provider": "Sqlite"
  },
  "StaffAuth": {
    "Key": "PLACEHOLDER-staff-key-not-a-real-secret-override-via-user-secrets"
  },
  "CheckInToken": {
    "SigningKey": "PLACEHOLDER-checkin-signing-key-not-a-real-secret-override-via-user-secrets"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4201",
      "http://localhost:4202"
    ],
    "AllowLoopbackOrigins": true
  },
  "UseAzureSignalR": false
}
