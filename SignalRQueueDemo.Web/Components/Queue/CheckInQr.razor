@using SignalRQueueDemo.Shared
@inject NavigationManager Navigation

<aside class="check-in-cta">
    <p class="cta-label">Check in from your phone</p>
    <div class="cta-qr">
        @((MarkupString)this.qrSvg)
    </div>
    <p class="cta-url">@this.checkInUrl</p>
</aside>

@code {
    // Self-contained by design: the Blazor board advertises its OWN /checkin page, not the Angular public-checkin
    // app. The URL is derived from the app's own base address (NavigationManager) — no PublicCheckinUrl config,
    // no awareness of the API or the Angular apps. Both URL and QR are computed once in OnInitialized rather than
    // in property getters, since neither changes for the app's lifetime and the Display board re-renders on every
    // QueueUpdated broadcast — re-encoding the SVG on each of those would be pure wasted work.
    private string checkInUrl = string.Empty;
    private string qrSvg = string.Empty;

    protected override void OnInitialized()
    {
        this.checkInUrl = Navigation.ToAbsoluteUri("checkin").ToString();
        this.qrSvg = QrCodeHelper.GenerateSvg(this.checkInUrl);
    }
}
