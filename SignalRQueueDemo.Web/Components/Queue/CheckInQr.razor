@using SignalRQueueDemo.Shared
@inject IConfiguration Configuration

@if (this.checkInUrl is not null)
{
    <aside class="check-in-cta">
        <p class="cta-label">Check in from your phone</p>
        @if (this.qrSvg is not null)
        {
            <div class="cta-qr">
                @((MarkupString)this.qrSvg)
            </div>
        }
        <p class="cta-url">@this.checkInUrl</p>
    </aside>
}

@code {
    // The check-in URL and its QR never change for the app's lifetime, so both are computed once in
    // OnInitialized rather than in property getters — the Display board re-renders on every QueueUpdated
    // broadcast, and re-encoding the SVG on each of those renders would be pure wasted work.
    private string? checkInUrl;
    private string? qrSvg;

    protected override void OnInitialized()
    {
        this.checkInUrl = Configuration["PublicCheckinUrl"];
        if (this.checkInUrl is not null)
        {
            this.qrSvg = QrCodeHelper.GenerateSvg(this.checkInUrl);
        }
    }
}
