@implements IDisposable
@inject QueueRealtimeService Realtime

<section class="waiting-list">
    <h2 class="section-title">Waiting (@this.WaitingEntries.Count)</h2>

    <div class="entries">
        @if (this.WaitingEntries.Count == 0)
        {
            <p class="empty-state">No one is currently waiting.</p>
        }
        else
        {
            @for (int i = 0; i < this.WaitingEntries.Count; i++)
            {
                QueueEntry entry = this.WaitingEntries[i];
                <div class="entry">
                    <div class="position">#@(i + 1)</div>
                    <div class="ticket-number">@entry.TicketNumber</div>
                    <div class="entry-name">@PublicName.ToPublicName(entry.DisplayName)</div>
                </div>
            }
        }
    </div>
</section>

@code {
    // Sorted by check-in time ascending (oldest first) so position on the board matches "next in line" — court
    // privacy: ticket number + name masked via PublicName, never servedBy.
    private List<QueueEntry> WaitingEntries => [.. (Realtime.Snapshot?.Queue ?? [])
        .Where(e => e.Status == QueueStatus.Waiting)
        .OrderBy(e => e.CheckedInAt)];

    protected override void OnInitialized() => Realtime.Changed += this.OnRealtimeChanged;

    private void OnRealtimeChanged() => this.InvokeAsync(this.StateHasChanged);

    public void Dispose() => Realtime.Changed -= this.OnRealtimeChanged;
}
