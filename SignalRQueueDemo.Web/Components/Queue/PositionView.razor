@implements IDisposable
@inject QueueRealtimeService Realtime
@inject QueueCancellationService CancellationService

<section class="position-view">
    @if (Realtime.ConnectionState == QueueConnectionState.Polling)
    {
        <p class="reconnecting" role="status">Reconnecting… your place is still saved.</p>
    }

    @switch (CurrentStatus)
    {
        case QueueStatus.Serving:
            <div class="state state-serving">
                <p class="eyebrow">It's your turn</p>
                <h1 class="headline">@CurrentEntry?.DisplayName, please come to the counter</h1>
                <p class="detail">Ticket @CurrentEntry?.TicketNumber</p>
            </div>
            break;
        case QueueStatus.Completed:
            <div class="state state-complete">
                <p class="eyebrow">All done</p>
                <h1 class="headline">Thank you, @CurrentEntry?.DisplayName</h1>
                <p class="detail">Removing from your list in @(secondsRemaining)s…</p>
            </div>
            break;
        default:
            <div class="state state-waiting">
                <p class="eyebrow">Checked in</p>
                <p class="position-number">#@CurrentPosition</p>
                <h1 class="headline">@(CurrentPosition == 1 ? "You're next" : "in line")</h1>
                <p class="detail">@(CurrentEntry?.DisplayName ?? SeedEntry.DisplayName) · Ticket @(CurrentEntry?.TicketNumber ?? SeedEntry.TicketNumber)</p>
            </div>
            break;
    }

    @if (CurrentStatus != QueueStatus.Completed)
    {
        <DocumentUpload EntryId="@EntryId" />
    }

    <button type="button" class="secondary-button" @onclick="this.StopTrackingAsync">
        @(CurrentStatus == QueueStatus.Completed ? "Clear" : "Stop tracking")
    </button>
</section>

@code {
    /// <summary>Auto-reset countdown after Completed — same duration as the Angular reference client's PositionView.</summary>
    private const int AutoResetSeconds = 10;

    [Parameter, EditorRequired]
    public string EntryId { get; set; } = string.Empty;

    /// <summary>Seed position from the direct check-in call's own response — rendered until the realtime snapshot first contains this entry.</summary>
    [Parameter, EditorRequired]
    public int SeedPosition { get; set; }

    /// <summary>Seed entry from the direct check-in call's own response — same "render immediately, then trust the snapshot" reasoning as SeedPosition.</summary>
    [Parameter, EditorRequired]
    public QueueEntry SeedEntry { get; set; } = null!;

    [Parameter]
    public EventCallback OnFinished { get; set; }

    private Timer? resetTimer;
    private int secondsRemaining = AutoResetSeconds;

    // Position is always derived live from the authoritative snapshot, never trusted from the seed beyond the
    // very first render — mirrors the Angular PositionView's documented behavior exactly.
    private QueueEntry? CurrentEntry =>
        Realtime.Snapshot?.Queue.FirstOrDefault(e => e.Id == this.EntryId);

    private QueueStatus CurrentStatus => this.CurrentEntry?.Status ?? this.SeedEntry.Status;

    private int CurrentPosition
    {
        get
        {
            if (Realtime.Snapshot is null)
            {
                return this.SeedPosition;
            }

            List<QueueEntry> waiting = [.. Realtime.Snapshot.Queue
                .Where(e => e.Status == QueueStatus.Waiting)
                .OrderBy(e => e.CheckedInAt)];
            int index = waiting.FindIndex(e => e.Id == this.EntryId);
            return index >= 0 ? index + 1 : this.SeedPosition;
        }
    }

    protected override void OnInitialized() => Realtime.Changed += this.OnRealtimeChanged;

    /// <summary>
    /// Manual "stop tracking this person" — mirrors the Angular reference client's <c>PositionView.startOver</c>
    /// exactly: drop the card locally first (the local UX must never wait on the backend round-trip), then fire
    /// a best-effort cancel so the entry also clears from the staff queue instead of sitting in it forever. Only
    /// cancels if the entry hadn't already reached Completed — the auto-reset countdown's own path
    /// (<see cref="Tick"/>) never calls this, so Completed entries are never redundantly "cancelled".
    /// </summary>
    private async Task StopTrackingAsync()
    {
        string entryId = this.EntryId;
        QueueStatus statusAtStop = this.CurrentStatus;

        this.resetTimer?.Dispose();
        this.resetTimer = null;

        await this.OnFinished.InvokeAsync();

        if (statusAtStop is QueueStatus.Waiting or QueueStatus.Serving)
        {
            // Fire-and-forget: this component is torn down by OnFinished above, so nothing past this point may
            // touch component state — only the captured entryId and injected (circuit-scoped, not
            // component-scoped) services are used. A failed cancel is swallowed, same as Angular: the card is
            // already gone locally, and the entry harmlessly stays in the staff queue.
            _ = this.CancelBestEffortAsync(entryId);
        }
    }

    private async Task CancelBestEffortAsync(string entryId)
    {
        try
        {
            QueueCancellationResult result = await CancellationService.CancelAsync(entryId);
            if (result.OperationResult.Outcome == QueueOperationOutcome.Success)
            {
                await Realtime.PublishAsync(result.OperationResult.Update!);
                if (result.DocumentsClearedUpdate is not null)
                {
                    await Realtime.PublishAsync(result.DocumentsClearedUpdate);
                }
            }
        }
        catch
        {
            // Swallowed on purpose — see StopTrackingAsync's remarks.
        }
    }

    private void OnRealtimeChanged() => this.InvokeAsync(() =>
    {
        if (this.CurrentStatus == QueueStatus.Completed)
        {
            this.StartResetCountdownIfNeeded();
        }

        this.StateHasChanged();
    });

    private void StartResetCountdownIfNeeded()
    {
        if (this.resetTimer is not null)
        {
            return;
        }

        this.resetTimer = new Timer(_ => this.InvokeAsync(this.Tick), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task Tick()
    {
        this.secondsRemaining--;
        if (this.secondsRemaining <= 0)
        {
            this.resetTimer?.Dispose();
            this.resetTimer = null;
            await this.OnFinished.InvokeAsync();
            return;
        }

        this.StateHasChanged();
    }

    public void Dispose()
    {
        Realtime.Changed -= this.OnRealtimeChanged;
        this.resetTimer?.Dispose();
    }
}
