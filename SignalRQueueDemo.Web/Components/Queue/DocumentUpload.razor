@using Microsoft.AspNetCore.Components.Forms
@inject DocumentUploadService UploadService
<section class="document-upload">
    <h2>Add a document (optional)</h2>
    <p class="hint">PDF, JPEG, or PNG, up to @(DocumentUploadService.MaxDocumentSizeBytes / 1024 / 1024)&nbsp;MB.</p>

    <!-- A styled <label> wrapping a visually-hidden <InputFile> gives a big, kiosk-friendly touch target
         while still using the native file picker (no custom drag-drop plumbing this POC doesn't need). -->
    <label class="upload-button @(this.uploading ? "disabled" : "")">
        @(this.uploading ? "Uploading…" : "Choose file")
        <InputFile class="visually-hidden" OnChange="this.HandleFileSelectedAsync" accept="@string.Join(",", DocumentUploadService.AllowedContentTypes)" disabled="@this.uploading" />
    </label>

    @if (this.errorMessage is not null)
    {
        <p class="error" role="alert">@this.errorMessage</p>
    }

    @if (this.uploadedFileNames.Count > 0)
    {
        <ul class="uploaded-list">
            @foreach (string name in this.uploadedFileNames)
            {
                <li>✓ @name</li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public string EntryId { get; set; } = string.Empty;

    [Inject] private QueueRealtimeService Realtime { get; set; } = default!;

    private bool uploading;
    private string? errorMessage;
    private readonly List<string> uploadedFileNames = [];

    // Client-side pre-check mirrors DocumentUploadService.MaxDocumentSizeBytes exactly — both read the same
    // constant, so unlike Angular's DocumentUpload component (which duplicates the number by hand and comments
    // "must match the server"), there's no separate value that can drift out of sync here.
    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        IBrowserFile file = e.File;

        if (file.Size > DocumentUploadService.MaxDocumentSizeBytes)
        {
            errorMessage = $"File exceeds the {DocumentUploadService.MaxDocumentSizeBytes / (1024 * 1024)} MB upload limit.";
            return;
        }

        uploading = true;
        try
        {
            await using Stream stream = file.OpenReadStream(DocumentUploadService.MaxDocumentSizeBytes);
            DocumentUploadResult result = await UploadService.UploadAsync(
                EntryId, file.Name, file.ContentType, file.Size, stream);

            if (result.Outcome == DocumentUploadOutcome.Success)
            {
                uploadedFileNames.Add(file.Name);
                if (result.Update is not null)
                {
                    await Realtime.PublishAsync(result.Update);
                }
            }
            else
            {
                errorMessage = result.Outcome switch
                {
                    DocumentUploadOutcome.EntryNotFound => "This check-in could not be found.",
                    DocumentUploadOutcome.LimitReached => "Maximum number of documents reached for this check-in.",
                    _ => result.FailureDetail ?? "Upload failed."
                };
            }
        }
        finally
        {
            uploading = false;
        }
    }
}
