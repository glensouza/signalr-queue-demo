@page "/display"
@implements IDisposable
@inject QueueRealtimeService Realtime

<PageTitle>Queue Display</PageTitle>

<main class="board">
    <div class="board-grid">
        <div class="now-serving-section">
            <NowServing />
        </div>
        <div class="waiting-section">
            <WaitingList />
        </div>
    </div>

    @if (Realtime.ConnectionState == QueueConnectionState.Polling)
    {
        <div class="reconnecting-banner">
            <p>Reconnecting…</p>
        </div>
    }

    <CheckInQr />
</main>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Subscribed here (not just in the child components) so this page's own "Reconnecting…" banner reacts to
        // ConnectionState changes too — NowServing/WaitingList only care about Snapshot.
        Realtime.Changed += this.OnRealtimeChanged;
        await Realtime.StartAsync();
    }

    private void OnRealtimeChanged() => this.InvokeAsync(this.StateHasChanged);

    public void Dispose() => Realtime.Changed -= this.OnRealtimeChanged;
}
